DB_PATH=data/options.duckdb

OPTION_CHAIN_WINDOW=20
DEFAULT_CP=C
RISK_FREE_RATE_FALLBACK=0.05

PAGE_SIZE=50

FETCH_CHAINS_ON_REFRESH=true
LARGE_CAP_CHAIN_THRESHOLD=200000000000

SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 */1 * * 1-5
SCHEDULER_WATCHLIST_DAYS_TO_EARNINGS=14

LARGE_CAP_SCHEDULER_ENABLED=true
LARGE_CAP_SCHEDULER_CRON=0 22 * * 1-5

IV_MONITOR_ENABLED=true
IV_MONITOR_CRON=*/10 * * * 1-5
IV_MONITOR_TIMEZONE=America/New_York
IV_MONITOR_BATCH_SIZE=15

DAILY_CANDLES_ENABLED=true
DAILY_CANDLES_CRON=*/10 * * * *
DAILY_CANDLES_BATCH_SIZE=10
DAILY_CANDLES_LOOKBACK_DAYS=90

WEB_HOST=127.0.0.1
WEB_PORT=8000
